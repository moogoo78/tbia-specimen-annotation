# Served by the `web` container (frontend/Dockerfile.prod).
#
# SITE_ADDRESS = your domain (e.g. tbia.example.org) -> automatic Let's Encrypt
#   TLS, or ":80" for plain HTTP (testing / IP-only; logins go in cleartext).
#
# CADDY_TLS  = TLS source. Leave UNSET for automatic Let's Encrypt (direct /
#   "DNS only" deployments). Behind a Cloudflare proxy (orange cloud), ACME is
#   blocked, so use a Cloudflare Origin Certificate and set:
#     CADDY_TLS="tls /etc/caddy/certs/cf-origin.pem /etc/caddy/certs/cf-origin.key"
#   (and set Cloudflare SSL/TLS mode to "Full (strict)"). See DEPLOY.md.
{$SITE_ADDRESS} {
	{$CADDY_TLS:}
	root * /srv

	# API -> backend container. Same origin, so the SPA's relative /api works.
	handle /api/* {
		reverse_proxy backend:8000
	}

	# SPA: serve the file if it exists, else fall back to index.html (client routing).
	handle {
		try_files {path} /index.html
		file_server
	}
}
